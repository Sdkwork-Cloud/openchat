{
  "name": "@openchat/opencat-admin-workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "app:update-create": "node ../../../scripts/app-update-create.mjs",
    "dev": "pnpm --filter @openchat/opencat-admin-web dev",
    "prepare:shared-sdk": "node ../../sdkwork-im-admin-sdk/bin/materialize-typescript-workspace.mjs",
    "build": "pnpm prepare:shared-sdk && pnpm --filter @openchat/opencat-admin-web build",
    "preview": "pnpm --filter @openchat/opencat-admin-web preview",
    "lint": "pnpm --filter @openchat/opencat-admin-web lint && pnpm check:arch && pnpm check:parity",
    "test": "pnpm --filter @openchat/opencat-admin-commons test && pnpm --filter @openchat/opencat-admin-infrastructure test && pnpm --filter @openchat/opencat-admin-core test && pnpm --filter @openchat/opencat-admin-ui test && pnpm --filter @openchat/opencat-admin-shell test && pnpm --filter @openchat/opencat-admin-system test",
    "clean": "pnpm --filter @openchat/opencat-admin-web clean",
    "check:arch": "node scripts/check-opencat-admin-structure.mjs",
    "check:parity": "pnpm check:routes && pnpm check:sdk && pnpm check:layers && pnpm check:theme",
    "check:routes": "node scripts/check-opencat-admin-route-surface.mjs",
    "check:sdk": "node scripts/check-opencat-admin-sdk-boundary.mjs",
    "check:layers": "node scripts/check-opencat-admin-layering.mjs",
    "check:theme": "node scripts/check-opencat-admin-semantic-theme.mjs",
    "check:types": "node scripts/run-workspace-tsc.mjs --noEmit"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.14.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^5.0.4",
    "jsdom": "^27.4.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.0.18"
  }
}
