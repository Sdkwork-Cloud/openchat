{
  "app": {
    "key": "openchat-react-mobile",
    "name": "OpenChat React Mobile",
    "description": null,
    "appType": "APP_REACT",
    "versionSource": "package.json",
    "packageName": null,
    "bundleId": null
  },
  "backend": {
    "profileKey": "backend-root-admin",
    "ownerMode": "tenant",
    "grantMode": "current",
    "platform": "WEB",
    "appId": "10001",
    "tenantId": "20001",
    "organizationId": null
  },
  "publish": {
    "status": "ACTIVE",
    "installSkill": {
      "name": "sdkwork-skills-app"
    },
    "platforms": [
      "APP",
      "APP_ANDROID",
      "APP_IOS"
    ],
    "installPlatforms": [
      "APP",
      "APP_ANDROID",
      "APP_IOS"
    ],
    "defaultPackageId": "mobile-app",
    "config": {
      "workspaceRoot": "apps/openchat/app/openchat-react-mobile",
      "framework": "react-capacitor",
      "managedBy": "apps/scripts/app-update-create.mjs"
    }
  },
  "environments": {
    "development": {
      "accessUrl": "https://api-dev.sdkwork.com/apps/openchat-react-mobile",
      "deployEnv": "development",
      "deployUrl": "https://api-dev.sdkwork.com/apps/openchat-react-mobile"
    },
    "test": {
      "accessUrl": "https://api-test.sdkwork.com/apps/openchat-react-mobile",
      "deployEnv": "test",
      "deployUrl": "https://api-test.sdkwork.com/apps/openchat-react-mobile"
    },
    "production": {
      "accessUrl": "https://api.sdkwork.com/apps/openchat-react-mobile",
      "deployEnv": "production",
      "deployUrl": "https://api.sdkwork.com/apps/openchat-react-mobile"
    }
  },
  "artifacts": {
    "packages": [
      {
        "id": "mobile-app",
        "name": "OpenChat React Mobile Mobile Bundle",
        "sourceType": "BINARY_URL",
        "packageFormat": "ZIP",
        "platform": "APP",
        "urlTemplate": "https://cdn.sdkwork.com/apps/openchat-react-mobile/{env}/{version}/mobile.zip",
        "enabled": true
      },
      {
        "id": "android-apk",
        "name": "OpenChat React Mobile Android APK",
        "sourceType": "BINARY_URL",
        "packageFormat": "APK",
        "platform": "APP_ANDROID",
        "urlTemplate": "https://cdn.sdkwork.com/apps/openchat-react-mobile/{env}/{version}/android.apk",
        "enabled": true
      },
      {
        "id": "ios-ipa",
        "name": "OpenChat React Mobile iOS IPA",
        "sourceType": "BINARY_URL",
        "packageFormat": "IPA",
        "platform": "APP_IOS",
        "urlTemplate": "https://cdn.sdkwork.com/apps/openchat-react-mobile/{env}/{version}/ios.ipa",
        "enabled": true
      }
    ],
    "runtimePayloads": {
      "CAPACITOR": {
        "updateManifestUrl": "https://cdn.sdkwork.com/apps/openchat-react-mobile/{env}/capacitor/update.json",
        "bundleUrl": "https://cdn.sdkwork.com/apps/openchat-react-mobile/{env}/{version}/capacitor.zip",
        "channel": "{env}"
      }
    },
    "metadata": {
      "workspaceRoot": "apps/openchat/app/openchat-react-mobile",
      "framework": "react-capacitor",
      "packageManager": "pnpm"
    }
  },
  "release": {
    "channel": "STABLE",
    "titleTemplate": "OpenChat React Mobile {version}",
    "summaryTemplate": "OpenChat React Mobile release {version} for {env}",
    "highlights": [
      "Unified pnpm app:update-create publish pipeline",
      "PlusApp metadata synchronized automatically",
      "Mobile package delivery metadata standardized"
    ],
    "forceUpdate": false,
    "metadata": {
      "ownerMode": "tenant",
      "framework": "react-capacitor"
    }
  }
}
