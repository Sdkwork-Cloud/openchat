{
  "name": "openchat-server",
  "version": "1.0.0",
  "description": "OpenChat Server - Enterprise-grade Real-time Communication Platform",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "node scripts/run-with-env.cjs development nest start --watch",
    "start:test": "node scripts/run-with-env.cjs test nest start",
    "start:debug": "node scripts/run-with-env.cjs development nest start --debug --watch",
    "start:openapi": "node scripts/start-openapi-server.cjs",
    "start:prod": "node scripts/run-with-env.cjs production node dist/main",
    "dev": "npm run start:dev",
    "lint": "node scripts/run-lint.js",
    "lint:eslint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:types": "tsc --noEmit",
    "test": "node scripts/run-with-env.cjs test jest --config jest.config.js",
    "test:watch": "node scripts/run-with-env.cjs test jest --config jest.config.js --watch",
    "test:cov": "node scripts/run-with-env.cjs test jest --config jest.config.js --coverage",
    "test:debug": "node scripts/run-with-env.cjs test node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --config jest.config.js --runInBand",
    "test:e2e": "node scripts/run-with-env.cjs test jest --config ./test/jest-e2e.json",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "db:drop": "npm run typeorm -- schema:drop",
    "db:sync": "npm run typeorm -- schema:sync",
    "db:init:dev": "node scripts/openchat-cli.cjs db init development",
    "db:init:test": "node scripts/openchat-cli.cjs db init test",
    "db:init:prod": "node scripts/openchat-cli.cjs db init production",
    "db:patch:dev": "node scripts/openchat-cli.cjs db patch development",
    "db:patch:test": "node scripts/openchat-cli.cjs db patch test",
    "db:patch:prod": "node scripts/openchat-cli.cjs db patch production",
    "bench:timeline": "node scripts/timeline-benchmark.js",
    "sdk:smoke": "node scripts/sdk-im-smoke.cjs"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.14",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.14",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/microservices": "^11.1.14",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.14",
    "@nestjs/platform-socket.io": "^11.1.14",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.14",
    "@socket.io/redis-adapter": "^8.3.0",
    "axios": "^1.13.5",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.70.1",
    "cache-manager": "^7.2.8",
    "cache-manager-ioredis": "^2.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "cron": "^4.4.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.3",
    "jsonwebtoken": "^9.0.3",
    "livekit-server-sdk": "^2.15.0",
    "mqtt": "^5.15.0",
    "nest-winston": "^1.10.2",
    "openai": "^6.24.0",
    "opusscript": "^0.1.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.18.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "telegraf": "^4.16.3",
    "typeorm": "^0.3.28",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.14",
    "@sdkwork/sdk-common": "^1.0.2",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/uuid": "^11.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.46.0",
    "@typescript-eslint/parser": "^8.46.0",
    "eslint": "^10.0.2",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "vite": "^7.0.0",
    "vite-plugin-dts": "^4.0.0"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
