{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@/(.*)$": "<rootDir>/../src/$1",
    "^src/(.*)$": "<rootDir>/../src/$1",
    "^uuid$": "<rootDir>/support/uuid-runtime.ts"
  },
  "setupFilesAfterEnv": ["./setup.ts"],
  "detectOpenHandles": true,
  "forceExit": true,
  "openHandlesTimeout": 2000
}
